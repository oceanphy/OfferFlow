# =================================
# OfferFlow — 环境变量配置
# =================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# --- 模型配置 ---
# 模型提供商：openai / deepseek / anthropic
# 注意：anthropic 需要额外安装 pip install anthropic 并重启服务
OFFERFLOW_PROVIDER=openai

# OpenAI 或 DeepSeek（两者都用 OpenAI 兼容协议，直接可用）
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OFFERFLOW_MODEL=gpt-4o-mini
OFFERFLOW_FALLBACK_MODEL=gpt-3.5-turbo

# DeepSeek 配置示例（取消下方注释，注释掉 OpenAI 配置即可）
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com
# OFFERFLOW_MODEL=deepseek-chat
# OFFERFLOW_FALLBACK_MODEL=deepseek-chat

# ---- 其他 ----
# 服务端口
OFFERFLOW_PORT=8000
